# Database
DATABASE_URL=postgresql+asyncpg://interviewlens:interviewlens_secret@localhost:5432/interviewlens
DATABASE_URL_SYNC=postgresql://interviewlens:interviewlens_secret@localhost:5432/interviewlens

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Whisper
WHISPER_MODEL=base

# Sandbox
SANDBOX_ENABLED=true
SANDBOX_TIMEOUT=5
SANDBOX_MEMORY_LIMIT=128m
SANDBOX_CPU_LIMIT=0.5

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
